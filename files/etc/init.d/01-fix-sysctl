#!/bin/sh
#
# 01-fix-sysctl — System tuning for bt-r320 eMMC
#
# Applied at boot via /etc/rc.local or uci-defaults
#
# - conntrack_max: increase for Docker/container workloads
# - vm.swappiness: reduce to favor RAM over eMMC swap
# - net.core.rmem/wmem: optimize for 2.5GbE throughput
# - vm.dirty_ratio: reduce to prevent sudden I/O spikes on eMMC

sysctl -w net.netfilter.nf_conntrack_max=65535 2>/dev/null
sysctl -w vm.swappiness=10 2>/dev/null
sysctl -w net.core.rmem_default=262144 2>/dev/null
sysctl -w net.core.rmem_max=16777216 2>/dev/null
sysctl -w net.core.wmem_default=262144 2>/dev/null
sysctl -w net.core.wmem_max=16777216 2>/dev/null
sysctl -w vm.dirty_ratio=5 2>/dev/null
